  "transcript": [
    {
      "id": "line-000",
      "start": 18.24,
      "end": 20.34,
      "text": "The Goat and the Vine.",
      "note": ""
    },
    {
      "id": "line-001",
      "start": 21.82,
      "end": 28.2,
      "text": "A goat was straying in a vineyard, and began to browse on the tender shoots of a vine,",
      "note": ""
    },
    {
      "id": "line-002",
      "start": 28.2,
      "end": 31.22,
      "text": "which bore several fine bunches of grapes.",
      "note": ""
    },
    {
      "id": "line-003",
      "start": 31.98,
      "end": 35.84,
      "text": "What have I done to you?\" said the Vine.",
      "note": ""
    },
    {
      "id": "line-004",
      "start": 36.36,
      "end": 38.56,
      "text": "That you should harm me thus.",
      "note": ""
    },
    {
      "id": "line-005",
      "start": 39.48,
      "end": 43.1,
      "text": "Isn't there grass enough for you to feed on?",
      "note": ""
    },
    {
      "id": "line-006",
      "start": 43.96,
      "end": 52.84,
      "text": "All the same, even if you eat up every leaf I have and leave me quite bare.",
      "note": ""
    },
    {
      "id": "line-007",
      "start": 53.8,
      "end": 63.26,
      "text": "I shall produce wine enough to pour over you when you are led to the altar to be sacrificed.",
      "note": ""
    },
    {
      "id": "line-008",
      "start": 64.58,
      "end": 67.06,
      "text": "End of The Goat and the Vine.",
      "note": ""
    }
  ],
