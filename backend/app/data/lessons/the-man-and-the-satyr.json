    },
    {
      "id": "line-004",
      "start": 18.58,
      "end": 24.0,
      "text": "Dunkleberg. D-U-N-K-E-L-B-E-R-G.com.",
      "note": ""
    },
    {
      "id": "line-005",
      "start": 25.26,
      "end": 27.72,
      "text": "ASOPs Fables, The Men, and A Sator.",
      "note": ""
    },
    {
      "id": "line-006",
      "start": 27.72,
      "end": 32.7,
      "text": "A man in a Sator became friends and determined to live together.",
      "note": ""
    },
    {
      "id": "line-007",
      "start": 33.28,
      "end": 36.94,
      "text": "All went well for a while until one day, in winter time.",
      "note": ""
    },
    {
      "id": "line-008",
      "start": 37.56,
      "end": 40.04,
      "text": "The Sator saw the man blowing on his hands.",
      "note": ""
    },
    {
      "id": "line-009",
      "start": 41.38,
      "end": 43.4,
      "text": "Why do you do that, he asked?",
      "note": ""
    },
    {
      "id": "line-010",
      "start": 44.02,
      "end": 46.34,
      "text": "To warm my hands, said the man.",
      "note": ""
    },
    {
      "id": "line-011",
      "start": 47.24,
      "end": 50.02,
      "text": "That same day, when they sat down to supper together,",
      "note": ""
    },
    {
      "id": "line-012",
      "start": 50.74,
      "end": 54.62,
      "text": "they each had a steaming, hot bowl of porridge.",
      "note": ""
    },
    {
      "id": "line-013",
      "start": 54.62,
      "end": 60.0,
      "text": "And the man raised his bowl to his mouth, and blew on it.",
      "note": ""
    },
    {
      "id": "line-014",
      "start": 61.1,
      "end": 63.54,
      "text": "Why do you do that, asked the Sator?",
      "note": ""
    },
    {
      "id": "line-015",
      "start": 64.14,
      "end": 66.96,
      "text": "To cool my porridge, said the man.",
      "note": ""
    },
    {
      "id": "line-016",
      "start": 67.66,
      "end": 69.34,
      "text": "The Sator got up from the table.",
      "note": ""
    },
    {
      "id": "line-017",
      "start": 69.64,
      "end": 71.6,
      "text": "Goodbye, said he. I'm going.",
      "note": ""
    },
    {
      "id": "line-018",
      "start": 72.16,
      "end": 77.16,
      "text": "I can't be friends with a man who blows hot and cold with the same breath.",
      "note": ""
    },
    {
      "id": "line-019",
      "start": 78.3,
      "end": 80.84,
      "text": "End of The Man and the Sator.",
      "note": ""
    }
  ],
