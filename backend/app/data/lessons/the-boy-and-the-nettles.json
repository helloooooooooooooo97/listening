    {
      "id": "line-003",
      "start": 13.18,
      "end": 14.0,
      "text": "Asop's Fables.",
      "note": ""
    },
    {
      "id": "line-004",
      "start": 15.46,
      "end": 19.34,
      "text": "The Boy and the Nettles A boy was gathering berries from a hedge",
      "note": ""
    },
    {
      "id": "line-005",
      "start": 19.34,
      "end": 21.26,
      "text": "when his hand was stung by a nettle.",
      "note": ""
    },
    {
      "id": "line-006",
      "start": 21.82,
      "end": 25.78,
      "text": "Smarting with the pain, he ran to tell his mother and said to her between his sobs,",
      "note": ""
    },
    {
      "id": "line-007",
      "start": 25.78,
      "end": 28.38,
      "text": "I only touched it ever so lightly, mother.",
      "note": ""
    },
    {
      "id": "line-008",
      "start": 28.96,
      "end": 31.82,
      "text": "That's just why you got stung, my son, she said.",
      "note": ""
    },
    {
      "id": "line-009",
      "start": 32.32,
      "end": 35.86,
      "text": "If you had grasped it firmly, it wouldn't have hurt you in the least.",
      "note": ""
    },
    {
      "id": "line-010",
      "start": 36.86,
      "end": 38.94,
      "text": "End of The Boy and the Nettles.",
      "note": ""
    }
  ],
