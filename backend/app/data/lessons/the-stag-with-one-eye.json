  "id": "the-stag-with-one-eye",
  "title": "The Stag With One Eye",
  "subtitle": "Aesop's Fables, Volume 06",
  "level": "A2-B1",
  "duration": 81.8,
  "audioFileName": "the-stag-with-one-eye.mp3",
