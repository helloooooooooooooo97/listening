    {
      "id": "line-005",
      "start": 22.22,
      "end": 23.68,
      "text": "ASAP's Fables.",
      "note": ""
    },
    {
      "id": "line-006",
      "start": 25.96,
      "end": 27.8,
      "text": "The Spend Thrift and the Swallow.",
      "note": ""
    },
    {
      "id": "line-007",
      "start": 29.02,
      "end": 37.88,
      "text": "A Spend Thrift who had wasted his fortune and had nothing left but the clothes in which he stood saw Swallow one fine day in early spring.",
      "note": ""
    },
    {
      "id": "line-008",
      "start": 39.18,
      "end": 44.96,
      "text": "Thinking that summer had come and that he could now do without his coat, he went and sold it for what it would fetch.",
      "note": ""
    },
    {
      "id": "line-009",
      "start": 46.04,
      "end": 52.28,
      "text": "A change, however, took place in the weather, and there came a sharp frost which killed the unfortunate Swallow.",
      "note": ""
    },
    {
      "id": "line-010",
      "start": 53.12,
      "end": 60.38,
      "text": "When the Spend Thrift saw its dead body, he cried, miserable bird, thanks to you I am perishing of cold myself.",
      "note": ""
    },
    {
      "id": "line-011",
      "start": 62.76,
      "end": 65.16,
      "text": "One Swallow does not make summer.",
      "note": ""
    },
    {
      "id": "line-012",
      "start": 67.98,
      "end": 70.82,
      "text": "End of the Spend Thrift and the Swallow.",
      "note": ""
    }
  ],
