    },
    {
      "id": "line-003",
      "start": 14.074,
      "end": 19.998,
      "text": "Recorded by Annie Coleman in St. Louis, Missouri on January 12, 2006.",
      "note": ""
    },
    {
      "id": "line-004",
      "start": 21.959,
      "end": 23.2,
      "text": "ASAP's Fables.",
      "note": ""
    },
    {
      "id": "line-005",
      "start": 24.521,
      "end": 25.842,
      "text": "The mice in Council.",
      "note": ""
    },
    {
      "id": "line-006",
      "start": 27.938,
      "end": 37.004,
      "text": "Once upon a time all the mice met together in council, and discussed the best means of securing themselves against the attacks of the cat.",
      "note": ""
    },
    {
      "id": "line-007",
      "start": 38.124,
      "end": 51.713,
      "text": "After several suggestions had been debated, a mouse of some standing in experience got up and said, I think I have hit upon a plan which will ensure our safety in the future, provided you approve and carry it out.",
      "note": ""
    },
    {
      "id": "line-008",
      "start": 52.542,
      "end": 60.304,
      "text": "It is that we should fasten a bell round the neck of our enemy the cat, which will, by its tinkling, warn us of her approach.",
      "note": ""
    },
    {
      "id": "line-009",
      "start": 61.704,
      "end": 80.349,
      "text": "This proposal was warmly applauded, and it had been already decided to adopt it, when an old mouse got upon his feet and said, I agree with you all that the plan before us is an admirable one, but may I ask, who is going to bell the cat?",
      "note": ""
    },
    {
      "id": "line-010",
      "start": 82.579,
      "end": 84.791,
      "text": "end of the mice in council.",
      "note": ""
    }
  ],
