  "transcript": [
    {
      "id": "line-000",
      "start": 0.0,
      "end": 6.5,
      "text": "This is a labor box recording. All labor box recordings are in the public domain.",
      "note": ""
    },
    {
      "id": "line-001",
      "start": 7.38,
      "end": 11.96,
      "text": "For more information or to volunteer, please visit laborbox.org.",
      "note": ""
    },
    {
      "id": "line-002",
      "start": 12.74,
      "end": 16.34,
      "text": "Recorded by Patty McCoy in Hudson, Colorado.",
      "note": ""
    },
    {
      "id": "line-003",
      "start": 17.8,
      "end": 28.04,
      "text": "ASOP's Fables, the three tradesmen. The citizens of a certain city were debating about the best material to use in the fortifications,",
      "note": ""
    },
    {
      "id": "line-004",
      "start": 29.12,
      "end": 33.74,
      "text": "which were about to be erected for the greater security of the town.",
      "note": ""
    },
    {
      "id": "line-005",
      "start": 34.02,
      "end": 42.4,
      "text": "A carpenter got up and advised the use of wood, which he said was regularly procurable and easily worked.",
      "note": ""
    },
    {
      "id": "line-006",
      "start": 42.68,
      "end": 50.64,
      "text": "A stone mason objected to the wood on the grounds that it was so implammable and recommended stones instead.",
      "note": ""
    },
    {
      "id": "line-007",
      "start": 51.34,
      "end": 62.42,
      "text": "Then the tander got on his legs and said, in my opinion, there's nothing like leather every man for himself, end of the three tradesmen.",
      "note": ""
    }
  ],
