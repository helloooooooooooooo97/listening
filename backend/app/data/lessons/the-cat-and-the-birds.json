    {
      "id": "line-005",
      "start": 20.6,
      "end": 21.52,
      "text": "The Cat and the Birds.",
      "note": ""
    },
    {
      "id": "line-006",
      "start": 22.6,
      "end": 29.24,
      "text": "A cat heard that the birds in an aviary were ailing, so he got himself up as a doctor",
      "note": ""
    },
    {
      "id": "line-007",
      "start": 29.24,
      "end": 35.5,
      "text": "and, taking with him a set of the instruments proper to his profession, presented himself",
      "note": ""
    },
    {
      "id": "line-008",
      "start": 35.5,
      "end": 38.36,
      "text": "at the door and inquired after the health of the birds.",
      "note": ""
    },
    {
      "id": "line-009",
      "start": 39.14,
      "end": 43.84,
      "text": "\"'We shall do very well,' they replied, without letting him in.",
      "note": ""
    },
    {
      "id": "line-010",
      "start": 44.56,
      "end": 47.04,
      "text": "\"'When we've seen the last of you.'\"",
      "note": ""
    },
    {
      "id": "line-011",
      "start": 48.2,
      "end": 52.06,
      "text": "A villain may disguise himself, but he will not deceive the wise.",
      "note": ""
    },
    {
      "id": "line-012",
      "start": 53.24,
      "end": 55.28,
      "text": "End of The Cat and the Birds.",
      "note": ""
    }
  ],
