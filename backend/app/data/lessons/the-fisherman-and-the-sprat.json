    },
    {
      "id": "line-002",
      "start": 13.94,
      "end": 17.94,
      "text": "Recorded by Gazina in Valletta, January 2006.",
      "note": ""
    },
    {
      "id": "line-003",
      "start": 20.24,
      "end": 21.44,
      "text": "ASOP's Fables.",
      "note": ""
    },
    {
      "id": "line-004",
      "start": 24.04,
      "end": 25.6,
      "text": "The Fisherman and the Sprat.",
      "note": ""
    },
    {
      "id": "line-005",
      "start": 28.1,
      "end": 38.4,
      "text": "The Fisherman cast his net into the sea, and when he drew it up again, it contained nothing but a single sprat that begged to be put back into the water.",
      "note": ""
    },
    {
      "id": "line-006",
      "start": 39.8,
      "end": 50.6,
      "text": "I'm only a little fish now, it said. But I shall grow big one day, and then if you come and catch me again, I shall be of some use to you.",
      "note": ""
    },
    {
      "id": "line-007",
      "start": 51.94,
      "end": 63.1,
      "text": "But the Fisherman replied, Oh no, I shall keep you now I've got you. If I put you back, should I ever see you again? Not likely.",
      "note": ""
    },
    {
      "id": "line-008",
      "start": 66.32,
      "end": 69.06,
      "text": "End of the Fisherman and the Sprat.",
      "note": ""
    }
  ],
