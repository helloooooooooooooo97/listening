{
  "id": "the-ox-and-the-frog",
  "title": "The Ox and The Frog",
  "subtitle": "Aesop's Fables, Volume 04",
  "level": "A2-B1",
  "duration": 71.3,
  "audioFileName": "the-ox-and-the-frog.mp3",
  "sourceURL": "https://librivox.org/aesops-fables-volume-4-fables-76-100/",
