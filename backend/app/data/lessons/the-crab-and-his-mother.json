    {
      "id": "line-004",
      "start": 19.56,
      "end": 20.44,
      "text": "Asop's Fables.",
      "note": ""
    },
    {
      "id": "line-005",
      "start": 21.74,
      "end": 23.0,
      "text": "The Crab and His Mother.",
      "note": ""
    },
    {
      "id": "line-006",
      "start": 25.72,
      "end": 27.42,
      "text": "An old crab said to her son,",
      "note": ""
    },
    {
      "id": "line-007",
      "start": 28.06,
      "end": 30.98,
      "text": "Why do you walk sideways like that, my son?",
      "note": ""
    },
    {
      "id": "line-008",
      "start": 31.52,
      "end": 33.02,
      "text": "You ought to walk straight.",
      "note": ""
    },
    {
      "id": "line-009",
      "start": 34.08,
      "end": 35.24,
      "text": "The young crab replied,",
      "note": ""
    },
    {
      "id": "line-010",
      "start": 36.38,
      "end": 37.58,
      "text": "Show me how, dear mother,",
      "note": ""
    },
    {
      "id": "line-011",
      "start": 38.12,
      "end": 39.46,
      "text": "And I'll follow your example.",
      "note": ""
    },
    {
      "id": "line-012",
      "start": 40.46,
      "end": 43.42,
      "text": "The old crab tried, but tried in vain,",
      "note": ""
    },
    {
      "id": "line-013",
      "start": 44.34,
      "end": 46.22,
      "text": "And then saw how foolish she had been",
      "note": ""
    },
    {
      "id": "line-014",
      "start": 46.22,
      "end": 48.18,
      "text": "To find fault with her child.",
      "note": ""
    },
    {
      "id": "line-015",
      "start": 49.54,
      "end": 50.14,
      "text": "Moral?",
      "note": ""
    },
    {
      "id": "line-016",
      "start": 50.86,
      "end": 52.6,
      "text": "Example is better than precept.",
      "note": ""
    },
    {
      "id": "line-017",
      "start": 54.16,
      "end": 55.24,
      "text": "End of Fable.",
      "note": ""
    },
    {
      "id": "line-018",
      "start": 57.42,
      "end": 57.42,
      "text": "",
      "note": ""
    }
