    },
    {
      "id": "line-003",
      "start": 11.88,
      "end": 15.76,
      "text": "Recorded by Christine Doer, the known as Assah, Florida.",
      "note": ""
    },
    {
      "id": "line-004",
      "start": 17.4,
      "end": 19.94,
      "text": "ESUPs Fables, the Quack Frog.",
      "note": ""
    },
    {
      "id": "line-005",
      "start": 21.16,
      "end": 26.76,
      "text": "Once upon a time a frog came forth from his home in the marshes and proclaimed to all",
      "note": ""
    },
    {
      "id": "line-006",
      "start": 26.76,
      "end": 33.1,
      "text": "the world that he was a learned physician, skilled in drugs and able to cure all diseases.",
      "note": ""
    },
    {
      "id": "line-007",
      "start": 34.38,
      "end": 39.64,
      "text": "Among the crowd was a fox who called out, you, a doctor?",
      "note": ""
    },
    {
      "id": "line-008",
      "start": 41.2,
      "end": 46.28,
      "text": "Why how can you set up to heal others when you cannot even cure your own lame legs and",
      "note": ""
    },
    {
      "id": "line-009",
      "start": 46.28,
      "end": 47.72,
      "text": "blotch dend wrinkled skin?",
      "note": ""
    },
    {
      "id": "line-010",
      "start": 49.5,
      "end": 51.5,
      "text": "Physician, healed by self.",
      "note": ""
    },
    {
      "id": "line-011",
      "start": 52.74,
      "end": 55.0,
      "text": "End of the Quack Frog.",
      "note": ""
    }
  ],
