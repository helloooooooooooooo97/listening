  "transcript": [
    {
      "id": "line-000",
      "start": 0.0,
      "end": 6.16,
      "text": "This is a labor box recording. All labor box recordings are in the public domain.",
      "note": ""
    },
    {
      "id": "line-001",
      "start": 7.0,
      "end": 11.58,
      "text": "For more information or to volunteer, please visit laborbox.org.",
      "note": ""
    },
    {
      "id": "line-002",
      "start": 13.0,
      "end": 15.98,
      "text": "Recorded by Patty McCoy in Hudson, Colorado.",
      "note": ""
    },
    {
      "id": "line-003",
      "start": 17.64,
      "end": 25.28,
      "text": "Asops Fables, the Fox and the Lion. A fox who had never seen a lion when they met one.",
      "note": ""
    },
    {
      "id": "line-004",
      "start": 25.28,
      "end": 31.98,
      "text": "It was so terrified at the sight of him that he was ready to die with fear.",
      "note": ""
    },
    {
      "id": "line-005",
      "start": 32.98,
      "end": 37.56,
      "text": "After time, he met him again and was still rather frightened,",
      "note": ""
    },
    {
      "id": "line-006",
      "start": 38.08,
      "end": 42.04,
      "text": "but not nearly so much as he had been when he met him first.",
      "note": ""
    },
    {
      "id": "line-007",
      "start": 43.36,
      "end": 48.06,
      "text": "But when he saw him for the third time, he was so far from being afraid",
      "note": ""
    },
    {
      "id": "line-008",
      "start": 48.06,
      "end": 53.74,
      "text": "that he went up to him and began to talk to him as if he had known him all his life.",
      "note": ""
    },
    {
      "id": "line-009",
      "start": 55.28,
      "end": 57.46,
      "text": "End of the Fox and the Lion.",
      "note": ""
    }
  ],
