    {
      "id": "line-003",
      "start": 17.452,
      "end": 22.757,
      "text": "This reading by Cara Schalenberg, www.krae.org.",
      "note": ""
    },
    {
      "id": "line-004",
      "start": 25.359,
      "end": 26.36,
      "text": "Asip's fables.",
      "note": ""
    },
    {
      "id": "line-005",
      "start": 28.481,
      "end": 30.343,
      "text": "The crow and the pitcher.",
      "note": ""
    },
    {
      "id": "line-006",
      "start": 33.445,
      "end": 46.788,
      "text": "A thirsty crow found a pitcher with some water in it, but so little was there that, try as she might, she could not reach it with her beak, and it seemed as though she would die of thirst within sight of the remedy.",
      "note": ""
    },
    {
      "id": "line-007",
      "start": 48.762,
      "end": 50.883,
      "text": "At last, she hid upon a clever plan.",
      "note": ""
    },
    {
      "id": "line-008",
      "start": 51.663,
      "end": 63.289,
      "text": "She began dropping pebbles into the pitcher, and with each pebble the water rose a little higher, until at last it reached the brim, and the knowing bird was enabled to quench her thirst.",
      "note": ""
    },
    {
      "id": "line-009",
      "start": 65.19,
      "end": 67.931,
      "text": "Necessity is the mother of invention.",
      "note": ""
    },
    {
      "id": "line-010",
      "start": 71.173,
      "end": 73.394,
      "text": "End of the crow and the pitcher.",
      "note": ""
    },
    {
      "id": "line-011",
      "start": 75.708,
      "end": 82.523,
      "text": "read by Cara Schalenberg on January 13th, 2006, in Oceanside, California.",
      "note": ""
    }
  ],
