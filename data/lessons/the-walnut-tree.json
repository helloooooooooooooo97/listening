    {
      "id": "line-005",
      "start": 16.9,
      "end": 17.7,
      "text": "The Walnut Tree.",
      "note": ""
    },
    {
      "id": "line-006",
      "start": 19.08,
      "end": 25.04,
      "text": "A Walnut Tree, which grew by the roadside, bore every year a plentiful crop of nuts.",
      "note": ""
    },
    {
      "id": "line-007",
      "start": 26.04,
      "end": 31.92,
      "text": "Everyone who passed by pelted its branches with sticks and stones in order to bring down",
      "note": ""
    },
    {
      "id": "line-008",
      "start": 31.92,
      "end": 34.64,
      "text": "the fruit and the tree suffered severely.",
      "note": ""
    },
    {
      "id": "line-009",
      "start": 35.62,
      "end": 42.78,
      "text": "It is hard, it cried, that the very persons who enjoy my fruit should thus reward me with",
      "note": ""
    },
    {
      "id": "line-010",
      "start": 42.78,
      "end": 43.88,
      "text": "insults and blows.",
      "note": ""
    },
    {
      "id": "line-011",
      "start": 44.98,
      "end": 46.94,
      "text": "End of the Walnut Tree.",
      "note": ""
    }
  ],
