      "text": "The moon and her mother.",
      "note": ""
    },
    {
      "id": "line-006",
      "start": 23.16,
      "end": 25.78,
      "text": "The moon once begged her mother to make her go.",
      "note": ""
    },
    {
      "id": "line-007",
      "start": 27.0,
      "end": 28.86,
      "text": "How can I reply she?",
      "note": ""
    },
    {
      "id": "line-008",
      "start": 29.82,
      "end": 31.58,
      "text": "There's no fit in your figure.",
      "note": ""
    },
    {
      "id": "line-009",
      "start": 32.64,
      "end": 37.2,
      "text": "At one time you're a new moon and at another you're a full moon and between whilst you're",
      "note": ""
    },
    {
      "id": "line-010",
      "start": 37.2,
      "end": 38.84,
      "text": "needed one nor the other.",
      "note": ""
    },
    {
      "id": "line-011",
      "start": 41.12,
      "end": 43.42,
      "text": "End of the moon and her mother.",
      "note": ""
    }
