    },
    {
      "id": "line-003",
      "start": 19.96,
      "end": 21.1,
      "text": "Isab's Fables.",
      "note": ""
    },
    {
      "id": "line-004",
      "start": 23.12,
      "end": 24.36,
      "text": "Jupiter and the Monkey.",
      "note": ""
    },
    {
      "id": "line-005",
      "start": 26.64,
      "end": 35.66,
      "text": "Jupiter issued a proclamation to all the beasts and offered a prize to the one who, in his judgment, produced the most beautiful offspring.",
      "note": ""
    },
    {
      "id": "line-006",
      "start": 37.2,
      "end": 44.28,
      "text": "Among the rest came the Monkey, carrying a baby monkey in her arms, a hairless, flat-nosed little fright.",
      "note": ""
    },
    {
      "id": "line-007",
      "start": 45.74,
      "end": 54.26,
      "text": "When they saw it, the gods all burst into peel-on peel of laughter, but the Monkey hugged her little one to her and said,",
      "note": ""
    },
    {
      "id": "line-008",
      "start": 55.46,
      "end": 62.62,
      "text": "Jupiter may give the prize to whom so ever he likes, but I shall always think my baby the most beautiful of them all.",
      "note": ""
    },
    {
      "id": "line-009",
      "start": 64.64,
      "end": 67.3,
      "text": "End of Jupiter and the Monkey.",
      "note": ""
    }
  ],
